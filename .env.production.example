NODE_ENV=production
PORT=8080
APP_BASE_URL=https://bubblev2.site

BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=your-brevo-smtp-login
BREVO_SMTP_PASS=your-brevo-smtp-key
AUTH_EMAIL_FROM="Bubble V2 <no-reply@bubblev2.site>"

# Production should verify email.
AUTH_BYPASS_EMAIL_VERIFICATION=false
